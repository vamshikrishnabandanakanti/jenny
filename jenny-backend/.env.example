# =============================================
# JENNY BACKEND — ENVIRONMENT VARIABLES
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# Server
PORT=3001
NODE_ENV=development

# Google Gemini API Key
# Get it free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model
# gemini-1.5-flash  → FREE tier, fast, great for MVP (recommended)
# gemini-1.5-pro    → Smarter, still free up to limits
GEMINI_MODEL=gemini-1.5-flash

# Session Memory (in-memory for MVP)
SESSION_TTL_MINUTES=30

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
